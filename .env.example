# ──────────────────────────────────────────────────────────────
# Equora — Environment Variables (template)
# Salin file ini ke .env.local lalu isi nilainya.
# JANGAN commit .env.local (sudah di-ignore git).
# ──────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Database: NeonDB (Postgres serverless) ───────────────────
# Connection string dari dashboard Neon (pakai yang "pooled" untuk app).
# Ini role OWNER: dipakai migrasi, seed, dan script (mem-bypass RLS).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# Direct (non-pooled) untuk migrasi Drizzle.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── RLS (A1): role app non-owner untuk menegakkan isolasi tenant ──
# KOSONGKAN untuk dev biasa → app jalan sebagai owner (RLS tak ditegakkan,
# scoping app-level seperti biasa). ISI untuk MENYALAKAN enforcement RLS:
#  1) set APP_DB_PASSWORD (password apa saja),
#  2) jalankan `npm run db:rls` (membuat role app_tenant + policy),
#  3) restart app. App lalu konek sebagai app_tenant (host/DB sama, kredensial
#     ditukar otomatis dari DATABASE_URL) dan policy RLS aktif.
APP_DB_USER="app_tenant"
APP_DB_PASSWORD=""

# ── Auth.js (NextAuth) ───────────────────────────────────────
# Generate: openssl rand -hex 32  (atau base64 32)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Kredensial super admin pertama (dipakai script: npm run seed:superadmin)
SUPERADMIN_EMAIL="admin@equora.id"
SUPERADMIN_PASSWORD="ganti-password-ini"
SUPERADMIN_NAME="Super Admin"

# ── Object storage: Vercel Blob ──────────────────────────────
# Token read-write dari dashboard Vercel (Storage → Blob → ".env.local").
# Selama kosong, tombol unggah disembunyikan (isStorageConfigured() = false).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_Jepkr1oyPGunpoJB_N8bsk4vaznJOpVN4rFYFrEIDkHJU6w"

# ── Email: Resend ────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Equora <noreply@equora.id>"

# ── Payments (Indonesia): Midtrans / Xendit ──────────────────
# Midtrans
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
# (Alternatif) Xendit
XENDIT_SECRET_KEY=""
XENDIT_WEBHOOK_TOKEN=""

# ── AI (provider-agnostic) ───────────────────────────────────
# Provider & model AKTIF bisa diganti via halaman Super Admin (disimpan
# di DB) — nilai di sini hanya DEFAULT/fallback saat DB belum diatur.
AI_PROVIDER="anthropic"          # anthropic | openai | google | (lainnya)
AI_MODEL="claude-opus-4-8"
# Isi key untuk provider yang dipakai (boleh lebih dari satu):
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
